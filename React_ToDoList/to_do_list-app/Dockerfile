FROM node:18-alpine

WORKDIR /app

COPY package*.json ./
RUN npm cache clean --force && npm install

COPY . .

EXPOSE 3000

CMD ["npm", "start"]

ARG REACT_APP_API_BASE_URL
ARG REACT_APP_AUTH_API_URL
ENV REACT_APP_API_BASE_URL=$REACT_APP_API_BASE_URL
ENV REACT_APP_AUTH_API_URL=$REACT_APP_AUTH_API_URL